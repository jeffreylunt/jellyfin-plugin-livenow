# Live Now guide daemon config (copy to /home/jeff/live-now-guide/live-now-guide.env)
JELLYFIN_URL=http://localhost:8096/jellyfin
JELLYFIN_TOKEN=REPLACE_WITH_API_KEY
JELLYFIN_USER_ID=727583f8f86b42b4ac500a28ddfe5f56
POLL_SECONDS=45

# Auto-favorite warm channels for ALL users so they float to the top of the native TV
# guide's favorites block (the only top-of-screen lever on the Android TV app). When a
# channel goes cold, the daemon removes ONLY the favorites it added (never a user's own).
ENABLE_AUTO_FAVORITE=true
# Persistent record of (userId, channelId) favorites the daemon added. Only these are ever
# removed. Lives next to the daemon so it survives restarts.
OWNED_FAVORITES_FILE=/home/jeff/live-now-guide/owned-favorites.json
# Per-user favorite reads run concurrently (the API is slow per call under load). Tune if
# the server drops connections under the read burst.
FAV_READ_WORKERS=4
FAV_READ_TIMEOUT=40
